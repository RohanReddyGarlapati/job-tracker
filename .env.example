# Copy to .env and fill in with your own Postgres database (e.g. Vercel Storage
# / Neon). DATABASE_URL is the pooled connection used at runtime; the Prisma
# schema also reads DATABASE_URL_UNPOOLED as `directUrl`, which Prisma Migrate
# needs since migrations can't run through a connection pooler.
DATABASE_URL="postgres://user:password@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@host/db?sslmode=require"
